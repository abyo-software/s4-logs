{
  "__inputs": [],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Operational dashboard for the s4logs-gateway (Mode B / 迂回): ingest, flush, compression ratio, CloudWatch passthrough errors, backpressure, and WAL durability health. Panels target only the Prometheus metrics the gateway actually emits from /metrics.",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["s4logs", "gateway", "cloudwatch-logs"],
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "prometheus",
        "queryValue": "",
        "refresh": 1,
        "regex": "",
        "skipUrlSync": false,
        "type": "datasource"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "",
  "title": "s4logs Gateway",
  "uid": "s4logs-gateway",
  "version": 1,
  "weekStart": "",
  "panels": [
    {
      "type": "timeseries",
      "title": "Events accepted / sec by action",
      "description": "rate(s4logs_events_total{action}) — PutLogEvents events split by routing action (s3 / cloudwatch / both). Stacked.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "stacking": {
              "mode": "normal",
              "group": "A"
            }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (action) (rate(s4logs_events_total[$__rate_interval]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Chunk flush rate",
      "description": "rate(s4logs_flush_total) — chunks flushed to the object store per second (size / age / shutdown / cap triggers combined).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(s4logs_flush_total[$__rate_interval]))",
          "legendFormat": "chunks/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Flush throughput: raw vs compressed bytes / sec",
      "description": "rate(s4logs_flush_bytes_total{kind=raw|compressed}) — uncompressed input vs stored (zstd) output byte rate.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 8
      },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum by (kind) (rate(s4logs_flush_bytes_total[$__rate_interval]))",
          "legendFormat": "{{kind}}",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "Live compression ratio (raw / compressed)",
      "description": "rate(s4logs_flush_bytes_total{kind=raw}) / rate(s4logs_flush_bytes_total{kind=compressed}) — effective zstd ratio over the window. Higher is better.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 2
              },
              {
                "color": "green",
                "value": 4
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(s4logs_flush_bytes_total{kind=\"raw\"}[$__rate_interval])) / clamp_min(sum(rate(s4logs_flush_bytes_total{kind=\"compressed\"}[$__rate_interval])), 1)",
          "legendFormat": "ratio",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "CloudWatch passthrough error rate",
      "description": "rate(s4logs_cw_passthrough_errors_total) — failed forwards to upstream CloudWatch Logs (PutLogEvents / CreateLogGroup / CreateLogStream). For 'both' routes these are logged but do not fail the client; for pure 'cloudwatch' routes they do.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "red"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(s4logs_cw_passthrough_errors_total[$__rate_interval]))",
          "legendFormat": "cw passthrough errors/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Backpressure (503) events / sec",
      "description": "rate(s4logs_backpressure_total) — batches rejected with 503 because max_buffered_bytes could not be honored even after force-flushing the largest buffer. Sustained non-zero means the gateway is memory-capped; raise --max-buffered-bytes or scale out.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 8,
        "y": 16
      },
      "id": 6,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          },
          "color": {
            "mode": "fixed",
            "fixedColor": "orange"
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        },
        "tooltip": {
          "mode": "single"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(s4logs_backpressure_total[$__rate_interval]))",
          "legendFormat": "backpressure/sec",
          "refId": "A"
        }
      ]
    },
    {
      "type": "stat",
      "title": "WAL error counters (cumulative)",
      "description": "Cumulative WAL error/anomaly counters since process start: torn lines skipped on replay, file fsync errors, and directory (dirent) fsync errors. Any non-zero value warrants investigation. Directory-fsync errors are tolerated on FUSE/NFS but should be zero on ext4/xfs.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "id": 7,
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "horizontal",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "value_and_name"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(s4logs_wal_torn_lines_total)",
          "legendFormat": "torn lines",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(s4logs_wal_fsync_errors_total)",
          "legendFormat": "file fsync errors",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(s4logs_wal_dir_fsync_errors_total)",
          "legendFormat": "dir fsync errors",
          "refId": "C"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WAL throughput: appends & replayed events / sec",
      "description": "rate(s4logs_wal_appends_total) — events fsynced to the WAL before ack; rate(s4logs_wal_replayed_events_total) — events recovered from surviving segments on startup (normally a brief spike right after a restart).",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 24
      },
      "id": 8,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["mean", "lastNotNull"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(s4logs_wal_appends_total[$__rate_interval]))",
          "legendFormat": "appends/sec",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(s4logs_wal_replayed_events_total[$__rate_interval]))",
          "legendFormat": "replayed/sec",
          "refId": "B"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "WAL error rate: torn lines, file & dir fsync errors / sec",
      "description": "Per-second view of the same WAL error counters as the stat panel — useful to correlate spikes with deploys, disk issues, or filesystem changes. All three should sit at zero in steady state.",
      "datasource": {
        "type": "prometheus",
        "uid": "${datasource}"
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 24
      },
      "id": 9,
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": ["sum"]
        },
        "tooltip": {
          "mode": "multi"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(s4logs_wal_torn_lines_total[$__rate_interval]))",
          "legendFormat": "torn lines/sec",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(s4logs_wal_fsync_errors_total[$__rate_interval]))",
          "legendFormat": "file fsync errors/sec",
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${datasource}"
          },
          "expr": "sum(rate(s4logs_wal_dir_fsync_errors_total[$__rate_interval]))",
          "legendFormat": "dir fsync errors/sec",
          "refId": "C"
        }
      ]
    }
  ]
}
