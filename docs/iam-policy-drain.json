{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S4LogsDrainReadCloudWatch",
      "Effect": "Allow",
      "Action": [
        "logs:FilterLogEvents",
        "logs:DescribeLogGroups"
      ],
      "Resource": "arn:aws:logs:*:YOUR_ACCOUNT_ID:log-group:*"
    },
    {
      "Sid": "S4LogsDrainShortenRetention",
      "Effect": "Allow",
      "Action": [
        "logs:PutRetentionPolicy"
      ],
      "Resource": "arn:aws:logs:*:YOUR_ACCOUNT_ID:log-group:*"
    },
    {
      "Sid": "S4LogsDrainWriteArchive",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::YOUR_BUCKET/s4logs/*"
    },
    {
      "Sid": "S4LogsDrainListArchivePrefix",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::YOUR_BUCKET",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "s4logs/*"
          ]
        }
      }
    }
  ]
}
