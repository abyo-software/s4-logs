{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "S4LogsGatewayWriteArchive",
      "Effect": "Allow",
      "Action": [
        "s3:PutObject",
        "s3:GetObject"
      ],
      "Resource": "arn:aws:s3:::YOUR_BUCKET/s4logs/*"
    },
    {
      "Sid": "S4LogsGatewayListArchivePrefix",
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket"
      ],
      "Resource": "arn:aws:s3:::YOUR_BUCKET",
      "Condition": {
        "StringLike": {
          "s3:prefix": [
            "s4logs/*"
          ]
        }
      }
    },
    {
      "Sid": "S4LogsGatewayCloudWatchPassthroughOptional",
      "Effect": "Allow",
      "Action": [
        "logs:PutLogEvents",
        "logs:CreateLogGroup",
        "logs:CreateLogStream"
      ],
      "Resource": "arn:aws:logs:*:YOUR_ACCOUNT_ID:log-group:*"
    }
  ]
}
